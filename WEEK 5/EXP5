<!DOCTYPE html>
<html>
<head>
    <title>Employee Payroll</title>
</head>
<body>

<h2>Employee Payroll System</h2>

<input type="text" id="name" placeholder="Employee Name">
<input type="number" id="salary" placeholder="Basic Salary">

<button onclick="generateSalary()">Generate Salary</button>

<div id="output"></div>

<script>

function Employee(name, basicSalary, hra = 2000, ta = 1000){

    this.name = name;
    this.basicSalary = basicSalary;
    this.hra = hra;
    this.ta = ta;

    this.calculateNetSalary = function(){

        let gross = this.basicSalary + this.hra + this.ta;
        let tax = gross * 0.10;
        let net = gross - tax;

        return `
            Employee Name : ${this.name} <br>
            Gross Salary : ${gross} <br>
            Tax : ${tax} <br>
            Net Salary : ${net}
        `;
    }
}

function generateSalary(){

    let name = document.getElementById("name").value;
    let salary = parseFloat(document.getElementById("salary").value);

    let emp = new Employee(name, salary);

    document.getElementById("output").innerHTML =
        emp.calculateNetSalary();
}

</script>

</body>
</html>
